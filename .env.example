#Flask Session cookie management 
SESSION_SECRET=your-secret-key-here
# Encryption
ENCRYPTION_MASTER_KEY=replace-with-a-long-random-secret
#This is your DATABASE_URL required for deployment when using a platform like neon postgresql
DATABASE_URL=your DB_URL
#This is the database user,passwd and db details required for local development
POSTGRES_USER= your-user
POSTGRES_PASSWORD= your-password
POSTGRES_DB= your-dbname
